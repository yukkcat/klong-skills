# Copy this file to .env and fill only the values you need.
# Process environment variables override values loaded from .env.
# These values appear in Prompt Studio as a read-only environment connection.
# They do not override another connection selected in Prompt Studio.

KLONG_API_KEY=
KLONG_BASE_URL=https://api.klong.lat
KLONG_DEFAULT_MODEL=gpt-image-2

# Optional. Leave empty to use the saved Studio location or outputs/prompt-studio.
KLONG_OUTPUT_DIR=

# Optional. Defaults to ~/.klong-image.
KLONG_STUDIO_HOME=
